# Report Template Generator Configuration

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=9099
DEBUG=false

# Ollama (local or remote)
# If Ollama is on the same machine: http://localhost:11434
# If Ollama is on another machine: http://192.168.x.x:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=90

# NAS Storage - Configure with your network details
# NAS_IP: IP address of your NAS on the network (e.g., 192.168.x.x)
# NAS_USERNAME: SMB username for NAS access
# NAS_PASSWORD: SMB password for NAS access
# NAS_MOUNT_PATH: Local mount point (ensure directory exists and is mounted)

NAS_IP=192.168.x.x
NAS_USERNAME=admin
NAS_PASSWORD=your_nas_password_here
NAS_SHARE=findings
NAS_MOUNT_PATH=/mnt/pentest-reports

# Logging
LOG_LEVEL=INFO
