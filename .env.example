# Report Template Generator Configuration

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false

# Ollama (local on same Mac Mini)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=90

# NAS Storage - CONFIGURE THESE WITH YOUR LAB DETAILS
# NAS_IP: Your Synology NAS IP on the lab network
# NAS_USERNAME: SMB username for NAS access
# NAS_PASSWORD: SMB password for NAS access
# NAS_MOUNT_PATH: Local mount point (ensure directory exists and is mounted)

NAS_IP=192.168.50.50
NAS_USERNAME=admin
NAS_PASSWORD=your_nas_password_here
NAS_SHARE=findings
NAS_MOUNT_PATH=/mnt/pentest-reports

# Logging
LOG_LEVEL=INFO
